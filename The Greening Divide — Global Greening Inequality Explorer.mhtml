input[type=3D"range"] { flex: 1 1 0%; accent-color: var(--amber); min-width=
: 160px; }

.btn { background: transparent; border: 1.5px solid var(--line); color: var=
(--ivory); font-family: Archivo; font-weight: 600; font-size: 0.85rem; bord=
